.venv/
foto/

# runtime watchdog
runtime/
*.pyc
__pycache__/

# comportamenti generati runtime
NAOTirocinio/behaviors/generated/*
NAOTirocinio/behaviors/generated_conditions/*

#solo init
!NAOTirocinio/behaviors/generated/__init__.py
!NAOTirocinio/behaviors/generated_conditions/__init__.py

# comportamenti generati runtime
behaviors/generated/*
!behaviors/generated/.gitkeep

# condizioni generate runtime
NAOTirocinio/behaviors/quarantine_conditions/*
NAOTirocinio/behaviors/rejected_conditions/*
NAOTirocinio/behaviors/generated_conditions/*

!NAOTirocinio/behaviors/quarantine_conditions/.gitkeep
!NAOTirocinio/behaviors/rejected_conditions/.gitkeep
!NAOTirocinio/behaviors/generated_conditions/.gitkeep

behaviors/rejected_conditions/
behaviors/quarantine_conditions/
behaviors/rejected_metadata/